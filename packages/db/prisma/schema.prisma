// Kopra schema v3 — sesuai docs/plans/2026-07-10-kopra-system-build-plan.md
// Keuangan ala "Koperasi Merah Putih CORE": COA hirarkis + jurnal double-entry;
// laporan (Buku Besar, Neraca Saldo, PHU, Neraca) DERIVED dari journal_lines.
// Identitas & registrasi: dual-flow WA/web, NIK plaintext by-requirement
// (redaksi ketat di layer aplikasi), super-admin WA-only.
// DB app = postgres docker :5433. Mirror data panitia = SOURCE_DATABASE_URL
// (hanya dibaca script gen-directory/import — tidak pernah oleh runtime).

generator client {
  provider = "prisma-client-js"
}

// CATATAN pgvector: extension & kolom embedding SENGAJA ditunda (unified plan
// #10 — RAG jalur kritis = Postgres FTS; vector = upgrade opsional saat deploy
// dgn image pgvector/pgvector). Dev lokal memakai Postgres 18 native tanpa vector.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum UserRole {
  OWNER // pemilik koperasi LOCAL (dibuat via approval super-admin)
  PENGURUS
  ANGGOTA
}

enum UserStatus {
  ACTIVE
  PENDING_OTP // web-register, belum verifikasi nomor WA
  PENDING_APPROVAL // menunggu super-admin (IMPORTED) / owner (LOCAL)
  REJECTED
}

enum KoperasiOrigin {
  IMPORTED // dari data resmi panitia
  LOCAL // dibuat via registrasi koperasi baru
}

enum KoperasiStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum CoaType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum EntrySource {
  WHATSAPP
  WEB
  SEED
  IMPORT
}

enum EntryStatus {
  DRAFT
  CONFIRMED
}

enum StockMoveType {
  IN
  OUT
  ADJUST
}

enum SavingType {
  POKOK
  WAJIB
}

enum SavingStatus {
  PAID
  UNPAID
}

enum RegType {
  MEMBER_JOIN
  NEW_KOPERASI
}

enum RegStatus {
  AWAITING_FORM
  AWAITING_OTP
  PENDING_SUPER_ADMIN
  PENDING_OWNER
  APPROVED
  REJECTED
  EXPIRED
}

enum WaGroupStatus {
  UNRESOLVED
  ATTACHED
}

enum PendingState {
  AWAITING_CONFIRM
  CONFIRMED
  CANCELLED
  EXPIRED
}

// ============ IDENTITAS & TENANCY ============

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  // NIK plaintext by-requirement (UNIQUE). JANGAN pernah tampil di response
  // biasa / log / prompt / audit payload — redaksi via core.redact.
  nik          String?    @unique
  role         UserRole   @default(ANGGOTA)
  status       UserStatus @default(ACTIVE)
  koperasiId   String? // 1 user = 1 koperasi (null = guest web)
  memberId     String?    @unique
  createdAt    DateTime   @default(now())

  koperasi       Koperasi?       @relation(fields: [koperasiId], references: [id])
  member         Member?         @relation(fields: [memberId], references: [id])
  waIdentities   WhatsappIdentity[]
  journalEntries JournalEntry[]
  stockMovements StockMovement[]
  pendingActions PendingAction[]
  auditLogs      AuditLog[]

  @@index([koperasiId, role])
  @@map("users")
}

model Koperasi {
  id             String         @id @default(cuid())
  nama           String
  desa           String?
  // ref profil_koperasi panitia (IMPORTED), mis. "KOP-539EF09CDAAD"
  sourceRef      String?        @unique
  origin         KoperasiOrigin @default(IMPORTED)
  status         KoperasiStatus @default(ACTIVE)
  // IMPORTED → "SUPER_ADMIN"; LOCAL → "OWNER"
  managementMode String         @default("SUPER_ADMIN")
  createdAt      DateTime       @default(now())

  users          User[]
  waIdentities   WhatsappIdentity[]
  members        Member[]
  businessUnits  BusinessUnit[]
  coaAccounts    CoaAccount[]
  journalEntries JournalEntry[]
  products       Product[]
  stockMovements StockMovement[]
  pendingActions PendingAction[]
  waGroups       WaGroup[]
  auditLogs      AuditLog[]

  @@map("koperasi")
}

model WhatsappIdentity {
  id         String @id @default(cuid())
  waNumber   String @unique // E.164 tanpa +, mis. 6281234567890
  userId     String
  koperasiId String

  user     User     @relation(fields: [userId], references: [id])
  koperasi Koperasi @relation(fields: [koperasiId], references: [id])

  @@map("whatsapp_identities")
}

model Member {
  id         String   @id @default(cuid())
  koperasiId String
  nama       String
  nik        String? // dari input pengurus / import (masked ok)
  waNumber   String?
  sourceRef  String?  @unique // anggota_koperasi panitia
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  koperasi Koperasi       @relation(fields: [koperasiId], references: [id])
  user     User?
  savings  MemberSaving[]

  @@index([koperasiId, nik])
  @@map("members")
}

// Simpanan per periode (pokok sekali, wajib bulanan; dukung bayar rapel).
model MemberSaving {
  id             String       @id @default(cuid())
  memberId       String
  type           SavingType
  period         String // "2026-01"; utk POKOK = periode daftar
  amount         Decimal      @db.Decimal(16, 2)
  status         SavingStatus @default(UNPAID)
  paidAt         DateTime?
  journalEntryId String? // jurnal saat pembayaran dikonfirmasi

  member Member @relation(fields: [memberId], references: [id])

  @@unique([memberId, type, period])
  @@index([memberId, status])
  @@map("member_savings")
}

// Unit usaha = DIMENSI pelaporan (BRILINK, POSPAY, BANEW, …), bukan akun.
model BusinessUnit {
  id           String  @id @default(cuid())
  koperasiId   String
  nama         String
  isActive     Boolean @default(true)
  revenueCoaId String?

  koperasi       Koperasi       @relation(fields: [koperasiId], references: [id])
  revenueCoa     CoaAccount?    @relation("BusinessUnitRevenueCoa", fields: [revenueCoaId, koperasiId], references: [id, koperasiId], onDelete: Restrict, onUpdate: Restrict, map: "business_units_revenueCoaId_fkey")
  journalEntries JournalEntry[]

  @@unique([koperasiId, nama])
  @@unique([revenueCoaId, koperasiId])
  @@map("business_units")
}

// ============ AKUNTANSI (ala CORE resmi) ============

model CoaAccount {
  id         String  @id @default(cuid())
  koperasiId String
  kode       String // "111000"
  nama       String // "Kas Rupiah"
  type       CoaType
  parentId   String?
  isActive   Boolean @default(true)

  koperasi Koperasi      @relation(fields: [koperasiId], references: [id])
  parent   CoaAccount?   @relation("CoaTree", fields: [parentId], references: [id])
  children CoaAccount[]  @relation("CoaTree")
  lines    JournalLine[]
  revenueForUnit BusinessUnit? @relation("BusinessUnitRevenueCoa")

  @@unique([koperasiId, kode])
  @@unique([id, koperasiId])
  @@map("coa_accounts")
}

// CONFIRMED immutable — koreksi = jurnal balik.
model JournalEntry {
  id             String      @id @default(cuid())
  koperasiId     String
  nomor          String // "JU-012" auto per koperasi
  referensi      String?
  date           DateTime    @default(now())
  keterangan     String
  businessUnitId String?
  sourceChannel  EntrySource
  status         EntryStatus @default(DRAFT)
  reversalOfId   String?
  createdById    String
  createdAt      DateTime    @default(now())

  koperasi      Koperasi       @relation(fields: [koperasiId], references: [id])
  businessUnit  BusinessUnit?  @relation(fields: [businessUnitId], references: [id])
  createdBy     User           @relation(fields: [createdById], references: [id])
  reversalOf    JournalEntry?  @relation("JournalReversal", fields: [reversalOfId, koperasiId], references: [id, koperasiId], onDelete: Restrict, onUpdate: Restrict, map: "journal_entries_reversalOfId_fkey")
  reversal      JournalEntry?  @relation("JournalReversal")
  lines         JournalLine[]
  stockMovement StockMovement?

  @@unique([koperasiId, nomor])
  @@unique([id, koperasiId])
  @@unique([reversalOfId, koperasiId])
  @@index([koperasiId, date])
  @@index([koperasiId, status])
  @@map("journal_entries")
}

// Per baris hanya salah satu debit/kredit terisi; balance divalidasi core.
model JournalLine {
  id      String  @id @default(cuid())
  entryId String
  coaId   String
  debit   Decimal @default(0) @db.Decimal(16, 2)
  kredit  Decimal @default(0) @db.Decimal(16, 2)
  catatan String?

  entry JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  coa   CoaAccount   @relation(fields: [coaId], references: [id])

  @@index([coaId])
  @@map("journal_lines")
}

// ============ INVENTARIS-LITE ============

model Product {
  id         String   @id @default(cuid())
  koperasiId String
  nama       String
  unit       String? // Pcs, kg, dus…
  barcode    String?
  hargaJual  Decimal? @db.Decimal(16, 2)
  isActive   Boolean  @default(true) // delete guard: ber-movement → inactive
  sourceRef  String?  @unique // produk_koperasi panitia
  createdAt  DateTime @default(now())

  koperasi  Koperasi        @relation(fields: [koperasiId], references: [id])
  movements StockMovement[]

  @@unique([koperasiId, nama])
  @@map("products")
}

// Stok terkini = SUM bertanda movement CONFIRMED (query, bukan kolom).
// Qty Decimal utk unit fraksional (kg, liter). CONFIRMED immutable —
// koreksi = ADJUST kompensasi.
model StockMovement {
  id             String        @id @default(cuid())
  koperasiId     String
  productId      String
  type           StockMoveType
  qty            Decimal       @db.Decimal(16, 3)
  hargaBeli      Decimal?      @db.Decimal(16, 2)
  hargaJual      Decimal?      @db.Decimal(16, 2)
  journalEntryId String?       @unique // jurnal uang linked (confirm atomik)
  date           DateTime      @default(now())
  sourceChannel  EntrySource
  status         EntryStatus   @default(DRAFT)
  createdById    String
  createdAt      DateTime      @default(now())

  koperasi     Koperasi      @relation(fields: [koperasiId], references: [id])
  product      Product       @relation(fields: [productId], references: [id])
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])
  createdBy    User          @relation(fields: [createdById], references: [id])

  @@index([koperasiId, productId, status])
  @@map("stock_movements")
}

// ============ REGISTRASI & APPROVAL ============

// Kandidat identitas dari data resmi panitia — BUKAN user terautentikasi.
model ImportedIdentity {
  id          String  @id @default(cuid())
  koperasiRef String // "KOP-…"
  sourceTable String // anggota|pengurus|karyawan_koperasi
  sourceRef   String  @unique
  nama        String
  nikMasked   String? // "3402**********01" → prefix match
  roleHint    String?

  @@index([koperasiRef, nikMasked])
  @@map("imported_identities")
}

model RegistrationRequest {
  id           String    @id @default(cuid())
  type         RegType
  channel      String // WA | WEB
  waNumber     String
  // PENGURUS | ANGGOTA (utk MEMBER_JOIN; NEW_KOPERASI otomatis OWNER)
  roleRequested String?
  // argon2 hash dari form web — dipakai membuat User saat approve (tidak pernah plaintext)
  passwordHash  String?
  nik          String? // plaintext by-requirement; redaksi di layer app
  nama         String?
  koperasiId   String?
  koperasiRef  String? // directory ref (IMPORTED belum onboarded)
  newKoperasi  Json? // {nama, alamat} utk NEW_KOPERASI
  candidateRef String? // ImportedIdentity.sourceRef pilihan super-admin
  status       RegStatus
  shortCode    String    @unique // "R-017" utk perintah WA super-admin
  expiresAt    DateTime // 24 jam
  decidedById  String?
  createdAt    DateTime  @default(now())

  @@index([status, createdAt])
  @@map("registration_requests")
}

model OtpChallenge {
  id        String    @id @default(cuid())
  waNumber  String
  otpHash   String
  attempts  Int       @default(0) // max 3
  expiresAt DateTime // TTL 300s
  usedAt    DateTime?
  requestId String?
  createdAt DateTime  @default(now())

  @@index([waNumber])
  @@map("otp_challenges")
}

// Magic link WA→web (single-use, TTL 900s).
model AuthToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique // sha256(token)
  waNumber  String
  payload   Json // {regRequestId}
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("auth_tokens")
}

// ============ PERCAKAPAN & DELIVERY ============

// Satu aktif per chat DM; preview→YA; expiry 900s; terminal-check dlm transaksi.
model PendingAction {
  id         String       @id @default(cuid())
  chatJid    String
  actorId    String
  koperasiId String
  actionType String // JOURNAL_SIMPLE|JOURNAL_MANUAL|STOCK_MOVE|SAVING_PAY|COA_CREATE|PRODUCT_CREATE|…
  preview    Json // efek lengkap yg ditampilkan ke user
  runId      String? // Mastra workflow run (snapshot persisted)
  state      PendingState @default(AWAITING_CONFIRM)
  expiresAt  DateTime
  createdAt  DateTime     @default(now())

  actor    User     @relation(fields: [actorId], references: [id])
  koperasi Koperasi @relation(fields: [koperasiId], references: [id])

  @@index([chatJid, state])
  @@map("pending_actions")
}

// Dedup webhook (idempotensi inbound).
model InboundWhatsappEvent {
  id        String   @id @default(cuid())
  deviceId  String
  eventId   String
  result    String? // PROCESSED|IGNORED|ERROR
  createdAt DateTime @default(now())

  @@unique([deviceId, eventId])
  @@map("inbound_wa_events")
}

// Outbox + retry backoff (idempotensi outbound; rate ≤1 msg/dtk).
model OutboundWhatsappMessage {
  id        String   @id @default(cuid())
  toJid     String
  text      String // DOCUMENT: dipakai sebagai caption
  kind      String   @default("TEXT") // TEXT|DOCUMENT
  payload   Json? // DOCUMENT: parameter laporan (ReportExportPayload)
  attempts  Int      @default(0)
  nextTryAt DateTime @default(now())
  status    String   @default("QUEUED") // QUEUED|SENT|FAILED
  createdAt DateTime @default(now())

  @@index([status, nextTryAt])
  @@map("outbound_wa_messages")
}

model WaGroup {
  id                 String        @id @default(cuid())
  groupJid           String        @unique // "1203…@g.us"
  nama               String?
  status             WaGroupStatus @default(UNRESOLVED)
  koperasiId         String?
  boundByUserId      String?
  lastParticipantsAt DateTime?
  createdAt          DateTime      @default(now())

  koperasi Koperasi?        @relation(fields: [koperasiId], references: [id])
  messages WaGroupMessage[]

  @@map("wa_groups")
}

// Konteks grup bounded: simpan 50 terbaru, prune >24 jam.
model WaGroupMessage {
  id        String   @id @default(cuid())
  groupJid  String
  sender    String // nomor pengirim
  text      String
  mentioned Boolean  @default(false)
  createdAt DateTime @default(now())

  group WaGroup @relation(fields: [groupJid], references: [groupJid], onDelete: Cascade)

  @@index([groupJid, createdAt])
  @@map("wa_group_messages")
}

// Direktori 1.026 koperasi resmi (nama publik, PII-free; seed dari JSON commit).
model KoperasiDirectory {
  sourceRef String  @id // "KOP-539EF09CDAAD"
  nama      String
  wilayah   String?

  @@map("koperasi_directory")
}

// ============ RAG & AUDIT ============

// Pencarian utama = Postgres FTS: kolom generated `tsv` + GIN index dibuat
// via SQL init (packages/db/sql/rag_fts.sql) karena Prisma belum dukung
// generated tsvector. Embedding pgvector = upgrade opsional saat deploy.
model RagDocument {
  id         String   @id @default(cuid())
  title      String
  source     String
  // regulation | guide | field_research | template | module_tutorial
  sourceType String
  content    String
  createdAt  DateTime @default(now())
  // Unsupported by Prisma Client, but represented here so `db push` preserves
  // the generated FTS column created by sql/rag_fts.sql.
  tsv        Unsupported("tsvector")? @default(dbgenerated("to_tsvector('simple'::regconfig, ((COALESCE(title, ''::text) || ' '::text) || COALESCE(content, ''::text)))"))

  @@index([tsv], type: Gin)
  @@map("rag_documents")
}

model AuditLog {
  id            String   @id @default(cuid())
  koperasiId    String?
  actorId       String?
  channel       String? // DM|GROUP|WEB|SYSTEM
  action        String
  resourceType  String?
  resourceRef   String?
  result        String? // OK|DENIED|ERROR
  correlationId String?
  payloadJson   Json? // WAJIB ter-redaksi (core.redact) sebelum tulis
  createdAt     DateTime @default(now())

  koperasi Koperasi? @relation(fields: [koperasiId], references: [id])
  actor    User?     @relation(fields: [actorId], references: [id])

  @@index([koperasiId, createdAt])
  @@map("audit_logs")
}
