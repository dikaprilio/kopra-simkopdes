# ===== App database (docker compose, port 5433 biar tak tabrakan Postgres lokal) =====
DATABASE_URL=postgresql://kopra:kopra@localhost:5433/kopra

# ===== Sumber data resmi panitia (mirror LOKAL read-only, hasil restore dump) =====
# JANGAN pakai kredensial shared DB panitia di sini — itu hanya di mesin dev, tak pernah di repo
SOURCE_DATABASE_URL=postgresql://postgres:admin@localhost:5432/hackathon_2026

# ===== LLM =====
ANTHROPIC_API_KEY=sk-ant-...
# STT voice note (Fase 2b, opsional)
