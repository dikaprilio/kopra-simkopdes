WA_WEBHOOK_SECRET=ganti-random-panjang     # WHATSAPP_WEBHOOK_SECRET (HMAC-SHA256)

# ===== Auth =====
JWT_SECRET=ganti-dengan-random-panjang

# ===== Ports =====
WEB_PORT=3000
API_PORT=3001
