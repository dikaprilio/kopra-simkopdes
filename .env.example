# ===== App database (docker compose, port 5433 biar tak tabrakan Postgres lokal) =====
DATABASE_URL=postgresql://kopra:kopra@localhost:5433/kopra

# ===== Sumber data resmi panitia (mirror LOKAL read-only, hasil restore dump) =====
# JANGAN pakai kredensial shared DB panitia di sini — itu hanya di mesin dev, tak pernah di repo
SOURCE_DATABASE_URL=postgresql://postgres:admin@localhost:5432/hackathon_2026

# ===== LLM =====
ANTHROPIC_API_KEY=sk-ant-...
# STT voice note (Fase 2b, opsional)
GROQ_API_KEY=

# ===== Gateway WhatsApp: GoWA v8.6.0 (repo kopra-whatsapp-waha / native lokal) =====
# v8 MULTI-DEVICE: semua call ke gateway WAJIB header X-Device-Id (lihat docs/plans/notes-gowa.md)
WA_GATEWAY_BASE_URL=http://localhost:3002
WA_GATEWAY_BASIC_AUTH=admin:kopra-dev
WA_WEBHOOK_SECRET=kopra-webhook-dev-secret   # header X-Hub-Signature-256 = sha256=HMAC(rawBody)
WA_DEVICE_ID=                                # isi setelah pairing QR nomor burner

# ===== Auth =====
JWT_SECRET=ganti-dengan-random-panjang

# ===== Ports =====
WEB_PORT=3000
API_PORT=3001
AGENT_PORT=4111

# ===== Registrasi & bot (unified plan) =====
APP_PUBLIC_WEB_URL=http://localhost:3000
OTP_TTL_SECONDS=300
MAGIC_LINK_TTL_SECONDS=900
PENDING_ACTION_TTL_SECONDS=900
SUPER_ADMIN_WA_NUMBER=628xxxxxxxxxx
